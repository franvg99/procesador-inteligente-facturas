    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  try {\n    const texto = item.json.output[0].content[0].text;\n    const datos = JSON.parse(texto);\n    return { json: datos };\n  } catch (error) {\n    return { \n      json: { \n        error: true, \n        mensaje: error.message,\n        texto_original: item.json.output[0].content[0].text\n      } \n    };\n  }\n});"
      },
